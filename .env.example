# ── Acesso ao painel (login único) ──────────────────────────────
PANEL_USERNAME=admin
PANEL_PASSWORD=CHANGE_ME

# Segredo que assina o cookie de sessão. Gere um valor longo e aleatório.
# Ex.: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_RANDOM_LONG_STRING

# ── Gateway WhatsApp ────────────────────────────────────────────
# Token JWT do gateway (mesmo $TOKEN usado nos seus curls). Vira o Bearer
# automaticamente; o navegador nunca enxerga. Se cada instância tiver um token
# próprio, dá pra sobrescrever por instância no JSON abaixo (campo "token").
GATEWAY_TOKEN=REPLACE_WITH_GATEWAY_JWT_TOKEN

# Prefixo das rotas no gateway (ROUTER_BASE_PATH).
GATEWAY_BASE_PATH=/api/v1/whatsapp

# Instâncias que aparecem no seletor do painel. Cada instância é um host:porta.
# Formato JSON (recomendado):
GATEWAY_INSTANCES=[{"label":"SP2 :10017 — cons 2202","baseUrl":"http://whatsapp-2-sp.smsnet.com.br:10017"},{"label":"SP2 :10005 — cons 2681 / wid 3005","baseUrl":"http://whatsapp-2-sp.smsnet.com.br:10005"},{"label":"SP1 :1000","baseUrl":"http://whatsapp-1-sp.smsnet.com.br:1000"}]
#
# Formato simples alternativo (separe por ';'):
# GATEWAY_INSTANCES=SP2 10017 = http://whatsapp-2-sp.smsnet.com.br:10017 ; SP2 10005 = http://whatsapp-2-sp.smsnet.com.br:10005

# Sufixos de host permitidos para o endpoint "Custom…" digitado no painel.
# Protege o token contra ser enviado a um host arbitrário. Separe por vírgula.
GATEWAY_ALLOWED_HOST_SUFFIXES=smsnet.com.br

# Opcional: instância única de fallback (usada se GATEWAY_INSTANCES ficar vazio).
# GATEWAY_BASE_URL=http://whatsapp-1-sp.smsnet.com.br:1000
