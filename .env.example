# ── Acesso ao painel (login único) ──────────────────────────────
PANEL_USERNAME=admin
PANEL_PASSWORD=CHANGE_ME

# Segredo que assina o cookie de sessão. Gere um valor longo e aleatório.
# Ex.: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_RANDOM_LONG_STRING

# ── Gateway WhatsApp ────────────────────────────────────────────
# URL base do gateway central (porta 1000). Pode incluir a porta diretamente
# (ex.: http://whatsapp-1-sp.smsnet.com.br:1000) ou deixar a porta ser
# definida via GATEWAY_CORE_PORT. Todas as chamadas usam SEMPRE esse host+porta
# — o gateway central consulta qualquer instância via banco de dados.
GATEWAY_BASE_URL=http://whatsapp-1-sp.smsnet.com.br

# Porta central do gateway. Usada quando GATEWAY_BASE_URL não inclui porta.
# Padrão: 1000 (único ponto de entrada aceito para todas as instâncias).
GATEWAY_CORE_PORT=1000

# Prefixo das rotas no gateway (ROUTER_BASE_PATH).
GATEWAY_BASE_PATH=/api/v1/whatsapp

# Senha usada em Basic Auth para obter o Bearer de cada instância.
# O username é o WID da instância (ex.: 12887).
GATEWAY_AUTH_PASSWORD=REPLACE_WITH_GATEWAY_AUTH_PASSWORD

# Instância âncora usada para carregar a lista de instâncias na abertura
# do painel, antes de o usuário selecionar uma. Sem esses valores a lista
# só carrega após o usuário selecionar manualmente uma instância.
GATEWAY_BOOTSTRAP_WID=12887
GATEWAY_BOOTSTRAP_PORT=1000

# Timeout padrão para chamadas ao gateway, em ms (fallback quando o cliente
# não enviar _timeoutMs). O painel envia o valor do campo "Timeout (s)" da UI.
# Mínimo: 5000 | Máximo: 300000 | Padrão: 60000
GATEWAY_TIMEOUT_MS=60000
